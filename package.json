{
  "name": "rbash",
  "version": "0.1.0",
  "description": "MCP server for remote bash execution via SSH",
  "type": "module",
  "bin": {
    "rbash": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.2",
    "commander": "^13.0.0",
    "ssh2": "^1.16.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ssh2": "^1.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT"
}
